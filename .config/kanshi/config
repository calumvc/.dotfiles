profile docked {
  output eDP-1 disable
  output DP-5 mode 2560x1440@144.00Hz position 0,0
  output HDMI-A-1 mode 1920x1080@143.99Hz
}

profile undocked {
  output eDP-1 enable
  output $TELLY enable

  output DP-6 mode 1920x1080@144
}

output "Toshiba America Info Systems Inc 43UHD_LCD_TV Unknown" {
  mode 3840x2160@60.000000
  position 0,0
  scale 2
  alias $TELLY
}

output "Iiyama North America PL8612U" {
  mode 3840x2160@60.000000
  position 0,0
  scale 4
  alias $BIGSCREEN
}
